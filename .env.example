# Local API and host routing
USE_LOCAL_API=
USE_BETA_API=
USE_LOCAL_CHATBOX=
USE_BETA_CHATBOX=

# Build and dev controls
CHATBOX_BUILD_PLATFORM=
CHATBOX_BUILD_TARGET=
NODE_ENV=
DEV_WEB_ONLY=
MAIN_ARGS=
PORT=1212
START_MINIMIZED=
DEBUG_PROD=
ANALYZE=
ELECTRON_RENDERER_URL=

# Chatbox integration and tests
CHATBOX_LICENSE_KEY=
CHATBOX_TEST_MODELS=
CHATBOX_TEST_TIMEOUT=120000
OPENAI_API_KEY=
TEST_OPENAI_API_KEY=
TEST_GEMINI_API_KEY=
TEST_OPENAI_RESPONSES_API_KEY=
OPENWEATHER_API_KEY=

# Release metadata and sourcemaps
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
SENTRY_DIST=
UPDATE_CHANNEL=latest

# Vercel CI/CD automation
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Desktop publish and notarization
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
APPLE_ID=
APPLE_ID_PASS=
APPLE_TEAM_ID=
