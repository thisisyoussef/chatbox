{
  "version": "2.9",
  "themes": {
    "mode": ["light", "dark"]
  },
  "variables": {
    "color.transparent": {
      "type": "color",
      "value": "#00000000"
    },
    "color.canvas": {
      "type": "color",
      "value": [
        { "value": "#FFFFFF", "theme": { "mode": "light" } },
        { "value": "#242424", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface": {
      "type": "color",
      "value": [
        { "value": "#F1F3F5", "theme": { "mode": "light" } },
        { "value": "#3B3B3B", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.hover": {
      "type": "color",
      "value": [
        { "value": "#F8F9FA", "theme": { "mode": "light" } },
        { "value": "#1F1F1F", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.muted": {
      "type": "color",
      "value": [
        { "value": "#DEE2E6", "theme": { "mode": "light" } },
        { "value": "#424242", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.selected": {
      "type": "color",
      "value": [
        { "value": "#E9F5FF", "theme": { "mode": "light" } },
        { "value": "#15324D", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.gray.soft": {
      "type": "color",
      "value": [
        { "value": "#F3F5F7", "theme": { "mode": "light" } },
        { "value": "#343A40", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.success.soft": {
      "type": "color",
      "value": [
        { "value": "#EAFBF5", "theme": { "mode": "light" } },
        { "value": "#124134", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.warning.soft": {
      "type": "color",
      "value": [
        { "value": "#FFF5D6", "theme": { "mode": "light" } },
        { "value": "#4B3A12", "theme": { "mode": "dark" } }
      ]
    },
    "color.surface.error.soft": {
      "type": "color",
      "value": [
        { "value": "#FFECEC", "theme": { "mode": "light" } },
        { "value": "#4C1919", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.primary": {
      "type": "color",
      "value": [
        { "value": "#212529", "theme": { "mode": "light" } },
        { "value": "#FFFFFF", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.secondary": {
      "type": "color",
      "value": [
        { "value": "#495057", "theme": { "mode": "light" } },
        { "value": "#CED4DA", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.tertiary": {
      "type": "color",
      "value": [
        { "value": "#868E96", "theme": { "mode": "light" } },
        { "value": "#828282", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.disabled": {
      "type": "color",
      "value": [
        { "value": "#ADB5BD", "theme": { "mode": "light" } },
        { "value": "#696969", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.inverse": {
      "type": "color",
      "value": "#FFFFFF"
    },
    "color.text.brand": {
      "type": "color",
      "value": [
        { "value": "#228BE6", "theme": { "mode": "light" } },
        { "value": "#4DABF7", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.success": {
      "type": "color",
      "value": [
        { "value": "#12B886", "theme": { "mode": "light" } },
        { "value": "#63E6BE", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.warning": {
      "type": "color",
      "value": [
        { "value": "#FAB005", "theme": { "mode": "light" } },
        { "value": "#FFE066", "theme": { "mode": "dark" } }
      ]
    },
    "color.text.error": {
      "type": "color",
      "value": [
        { "value": "#FA5252", "theme": { "mode": "light" } },
        { "value": "#F03E3E", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.default": {
      "type": "color",
      "value": [
        { "value": "#DEE2E6", "theme": { "mode": "light" } },
        { "value": "#495057", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.muted": {
      "type": "color",
      "value": [
        { "value": "#CED4DA", "theme": { "mode": "light" } },
        { "value": "#868E96", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.brand": {
      "type": "color",
      "value": [
        { "value": "#228BE6", "theme": { "mode": "light" } },
        { "value": "#1971C2", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.success": {
      "type": "color",
      "value": [
        { "value": "#12B886", "theme": { "mode": "light" } },
        { "value": "#63E6BE", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.warning": {
      "type": "color",
      "value": [
        { "value": "#FAB005", "theme": { "mode": "light" } },
        { "value": "#FFE066", "theme": { "mode": "dark" } }
      ]
    },
    "color.border.error": {
      "type": "color",
      "value": [
        { "value": "#FA5252", "theme": { "mode": "light" } },
        { "value": "#F03E3E", "theme": { "mode": "dark" } }
      ]
    },
    "color.fill.brand": {
      "type": "color",
      "value": [
        { "value": "#228BE6", "theme": { "mode": "light" } },
        { "value": "#1971C2", "theme": { "mode": "dark" } }
      ]
    },
    "color.fill.brand.hover": {
      "type": "color",
      "value": [
        { "value": "#1C7ED6", "theme": { "mode": "light" } },
        { "value": "#1864AB", "theme": { "mode": "dark" } }
      ]
    },
    "color.fill.brand.pressed": {
      "type": "color",
      "value": [
        { "value": "#1971C2", "theme": { "mode": "light" } },
        { "value": "#14538D", "theme": { "mode": "dark" } }
      ]
    },
    "color.fill.gray": {
      "type": "color",
      "value": [
        { "value": "#868E96", "theme": { "mode": "light" } },
        { "value": "#343A40", "theme": { "mode": "dark" } }
      ]
    },
    "color.fill.error": {
      "type": "color",
      "value": [
        { "value": "#FA5252", "theme": { "mode": "light" } },
        { "value": "#E03131", "theme": { "mode": "dark" } }
      ]
    },
    "color.overlay": {
      "type": "color",
      "value": [
        { "value": "#0000001F", "theme": { "mode": "light" } },
        { "value": "#00000052", "theme": { "mode": "dark" } }
      ]
    },
    "space.3xs": { "type": "number", "value": 2 },
    "space.xxs": { "type": "number", "value": 4 },
    "space.xs": { "type": "number", "value": 8 },
    "space.sm": { "type": "number", "value": 12 },
    "space.md": { "type": "number", "value": 16 },
    "space.lg": { "type": "number", "value": 20 },
    "space.xl": { "type": "number", "value": 24 },
    "space.xxl": { "type": "number", "value": 32 },
    "radius.none": { "type": "number", "value": 0 },
    "radius.xs": { "type": "number", "value": 2 },
    "radius.sm": { "type": "number", "value": 4 },
    "radius.md": { "type": "number", "value": 8 },
    "radius.lg": { "type": "number", "value": 16 },
    "radius.xl": { "type": "number", "value": 24 },
    "radius.xxl": { "type": "number", "value": 32 },
    "radius.pill": { "type": "number", "value": 999 },
    "type.caption": { "type": "number", "value": 12 },
    "type.label": { "type": "number", "value": 13 },
    "type.body": { "type": "number", "value": 15 },
    "type.subtitle": { "type": "number", "value": 18 },
    "type.title": { "type": "number", "value": 24 },
    "type.hero": { "type": "number", "value": 32 },
    "size.icon.sm": { "type": "number", "value": 16 },
    "size.icon.md": { "type": "number", "value": 20 },
    "size.control.sm": { "type": "number", "value": 32 },
    "size.control.md": { "type": "number", "value": 36 },
    "size.control.lg": { "type": "number", "value": 40 },
    "size.control.xl": { "type": "number", "value": 44 }
  },
  "children": [
    {
      "id": "system_context",
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 1320,
      "height": 48,
      "textGrowth": "fixed-width-height",
      "fontSize": 14,
      "lineHeight": 1.4,
      "fill": "$color.text.secondary",
      "content": "Chatbox Pencil foundation library aligned to src/renderer/static/globals.css and the current renderer patterns in MiniButton, SessionItem, ActionMenu, AdaptiveModal, SegmentedControl, Divider, and Page."
    },
    {
      "id": "system_status",
      "type": "text",
      "x": 0,
      "y": 54,
      "width": 1320,
      "height": 40,
      "textGrowth": "fixed-width-height",
      "fontSize": 14,
      "lineHeight": 1.4,
      "fill": "$color.text.secondary",
      "content": "This first-pass comprehensive library is organized in canvas sections: buttons and primitives, forms and states, app chrome, content patterns, overlay shells, and layout templates. Future stories should extend these primitives instead of sketching new one-off geometry."
    },
    {
      "id": "section-primitives_heading",
      "type": "text",
      "x": 0,
      "y": 108,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "Buttons and primitives"
    },
    {
      "id": "section-primitives_note",
      "type": "text",
      "x": 0,
      "y": 134,
      "width": 760,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Core actions, pills, dividers, avatars, and small shared building blocks."
    },
    {
      "id": "section-forms_heading",
      "type": "text",
      "x": 0,
      "y": 272,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "Forms and states"
    },
    {
      "id": "section-forms_note",
      "type": "text",
      "x": 0,
      "y": 298,
      "width": 760,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Field metadata, inputs, selectors, and common interaction states."
    },
    {
      "id": "section-chrome_heading",
      "type": "text",
      "x": 1100,
      "y": 108,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "App chrome and navigation"
    },
    {
      "id": "section-chrome_note",
      "type": "text",
      "x": 1100,
      "y": 134,
      "width": 720,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Headers, toolbars, nav rows, session rows, sidebars, and menus."
    },
    {
      "id": "section-content_heading",
      "type": "text",
      "x": 0,
      "y": 640,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "Content patterns"
    },
    {
      "id": "section-content_note",
      "type": "text",
      "x": 0,
      "y": 666,
      "width": 760,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Cards, rows, metrics, destinations, notices, and empty states."
    },
    {
      "id": "section-overlays_heading",
      "type": "text",
      "x": 1400,
      "y": 390,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "Overlay shells"
    },
    {
      "id": "section-overlays_note",
      "type": "text",
      "x": 1400,
      "y": 416,
      "width": 520,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Desktop modal, mobile sheet, and shared dialog body patterns."
    },
    {
      "id": "section-layouts_heading",
      "type": "text",
      "x": 0,
      "y": 1184,
      "textGrowth": "auto",
      "fontSize": "$type.subtitle",
      "fontWeight": "700",
      "fill": "$color.text.primary",
      "content": "Layout templates"
    },
    {
      "id": "section-layouts_note",
      "type": "text",
      "x": 0,
      "y": 1210,
      "width": 900,
      "height": 20,
      "textGrowth": "fixed-width-height",
      "fontSize": "$type.caption",
      "fill": "$color.text.tertiary",
      "content": "Page shells, multi-column layouts, split panes, and settings stacks."
    },
    {
      "id": "ds_field_label_stack",
      "name": "Field Label Stack",
      "type": "frame",
      "reusable": true,
      "x": 740,
      "y": 200,
      "width": 220,
      "height": 42,
      "layout": "vertical",
      "gap": "$space.3xs",
      "children": [
        {
          "id": "field-label-stack_label",
          "type": "text",
          "content": "Field label",
          "textGrowth": "auto",
          "fontSize": "$type.label",
          "fontWeight": "600",
          "fill": "$color.text.primary"
        },
        {
          "id": "field-label-stack_helper",
          "type": "text",
          "content": "Short helper text or context note.",
          "textGrowth": "fixed-width",
          "width": 220,
          "fontSize": "$type.caption",
          "lineHeight": 1.4,
          "fill": "$color.text.tertiary"
        }
      ]
    },
    {
      "id": "ds_button_primary",
      "name": "Button Primary",
      "type": "frame",
      "reusable": true,
      "x": 0,
      "y": 140,
      "width": 180,
      "height": 40,
      "cornerRadius": "$radius.md",
      "fill": "$color.fill.brand",
      "layout": "horizontal",
      "gap": "$space.xs",
      "justifyContent": "center",
      "alignItems": "center",
      "padding": ["$space.xs", "$space.md"],
      "children": [
        {
          "id": "button-primary_icon",
          "type": "icon_font",
          "iconFontFamily": "lucide",
          "iconFontName": "arrow-right",
          "width": "$size.icon.sm",
          "height": "$size.icon.sm",
          "fill": "$color.text.inverse"
        },
        {
          "id": "button-primary_label",
          "type": "text",
          "content": "Continue",
          "textGrowth": "auto",
          "fontSize": "$type.label",
          "fontWeight": "700",
          "fill": "$color.text.inverse"
        }
      ]
    },
    {
      "id": "ds_button_secondary",
      "name": "Button Secondary",
      "type": "ref",
      "reusable": true,
      "ref": "ds_button_primary",
      "x": 200,
      "y": 140,
      "fill": "$color.surface",
      "stroke": { "thickness": 1, "fill": "$color.border.default" },
      "descendants": {
        "button-primary_icon": {
          "fill": "$color.text.primary"
        },
        "button-primary_label": {
          "content": "Cancel",
          "fill": "$color.text.primary"
        }
      }
    },
    {
      "id": "ds_button_destructive",
      "name": "Button Destructive",
      "type": "ref",
      "reusable": true,
      "ref": "ds_button_primary",
      "x": 400,
      "y": 140,
      "fill": "$color.surface.error.soft",
      "stroke": { "thickness": 1, "fill": "$color.border.error" },
      "descendants": {
        "button-primary_icon": {
          "iconFontName": "trash-2",
          "fill": "$color.text.error"
        },
        "button-primary_label": {
          "content": "Delete",
          "fill": "$color.text.error"
        }
      }
    },
    {
      "id": "ds_button_disabled",
      "name": "Button Disabled",
      "type": "ref",
      "reusable": true,
      "ref": "ds_button_secondary",
      "x": 600,
      "y": 140,
      "opacity": 0.6,
      "descendants": {
        "button-primary_icon": {
          "fill": "$color.text.disabled"
        },
        "button-primary_label": {
          "content": "Unavailable",
          "fill": "$color.text.disabled"
        }
      }
    },
    {
      "id": "ds_button_loading",
      "name": "Button Loading",
      "type": "ref",
      "reusable": true,
      "ref": "ds_button_primary",
      "x": 800,
      "y": 140,
      "descendants": {
        "button-primary_icon": {
          "iconFontName": "loader-circle"
        },
        "button-primary_label": {
          "content": "Working..."
        }
      }
    },
    {
      "id": "ds_button_primary_pressed",
      "name": "Button Primary Pressed",
      "type": "ref",
      "reusable": true,
      "ref": "ds_button_primary",
      "x": 1000,
      "y": 140,
      "fill": "$color.fill.brand.pressed",
      "descendants": {
        "button-primary_label": {
          "content": "Pressed"
        }
      }
    },
    {
      "id": "ds_icon_button",
      "name": "Icon Button",
      "type": "frame",
      "reusable": true,
      "x": 0,
      "y": 206,
      "width": 32,
      "height": 32,
      "cornerRadius": "$radius.sm",
      "fill": "$color.transparent",
      "layout": "horizontal",
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "id": "icon-button_icon",
          "type": "icon_font",
          "iconFontFamily": "lucide",
          "iconFontName": "settings-2",
          "width": "$size.icon.sm",
          "height": "$size.icon.sm",
          "fill": "$color.text.secondary"
        }
      ]
    },
    {
      "id": "ds_icon_button_hover",
      "name": "Icon Button Hover",
      "type": "ref",
      "reusable": true,
      "ref": "ds_icon_button",
      "x": 48,
      "y": 206,
      "fill": "$color.surface.gray.soft"
    },
    {
      "id": "ds_badge",
      "name": "Badge",
      "type": "frame",
      "reusable": true,
      "x": 104,
      "y": 208,
      "width": 128,
      "height": 28,
      "cornerRadius": "$radius.pill",
      "fill": "$color.surface.warning.soft",
      "layout": "horizontal",
      "justifyContent": "center",
      "alignItems": "center",
      "padding": ["$space.xxs", "$space.sm"],
      "children": [
        {
          "id": "badge_label",
          "type": "text",
          "content": "Safety check",
          "textGrowth": "auto",
          "fontSize": "$type.caption",
          "fontWeight": "700",
          "fill": "$color.text.warning"
        }
      ]
    },
    {
      "id": "ds_action_chip",
      "name": "Action Chip",
      "type": "frame",
      "reusable": true,
      "x": 248,
      "y": 206,
      "width": 176,
      "height": 32,
      "cornerRadius": "$radius.pill",
      "fill": "$color.surface.selected",
      "layout": "horizontal",
      "gap": "$space.xxs",
      "justifyContent": "center",
      "alignItems": "center",
      "padding": ["$space.xxs", "$space.md"],
      "children": [
        {
          "id": "action-chip_icon",
          "type": "icon_font",
          "iconFontFamily": "lucide",
          "iconFontName": "sparkles",
          "width": "$size.icon.sm",
          "height": "$size.icon.sm",
          "fill": "$color.text.brand"
        },
        {
          "id": "action-chip_label",
          "type": "text",
          "content": "Quick action",
          "textGrowth": "auto",
          "fontSize": "$type.label",
          "fontWeight": "700",
          "fill": "$color.text.brand"
        }
      ]
    },
    {
      "id": "ds_divider_horizontal",
      "name": "Divider Horizontal",
      "type": "rectangle",
      "reusable": true,
      "x": 448,
      "y": 222,
      "width": 220,
      "height": 1,
      "fill": "$color.border.default"
    },
    {
      "id": "ds_divider_vertical",
      "name": "Divider Vertical",
      "type": "rectangle",
      "reusable": true,
      "x": 688,
      "y": 184,
      "width": 1,
      "height": 72,
      "fill": "$color.border.default"
    },
    {
      "id": "ds_avatar",
      "name": "Avatar",
      "type": "frame",
      "reusable": true,
      "x": 710,
      "y": 198,
      "width": 40,
      "height": 40,
      "cornerRadius": "$radius.pill",
      "fill": "$color.surface.selected",
      "layout": "horizontal",
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "id": "avatar_initial",
          "type": "text",
          "content": "A",
          "textGrowth": "auto",
          "fontSize": "$type.label",
          "fontWeight": "700",
          "fill": "$color.text.brand"
        }
      ]
    },
    {
      "id": "ds_text_input",
      "name": "Text Input",
      "type": "frame",
      "reusable": true,
      "x": 0,
      "y": 300,
      "width": 320,
      "height": 82,
      "layout": "vertical",
      "gap": "$space.xxs",
      "children": [
        {
          "id": "text-input_label",
          "type": "text",
          "content": "Display name",
          "textGrowth": "auto",
          "fontSize": "$type.label",
          "fontWeight": "600",
          "fill": "$color.text.primary"
        },
        {
          "id": "text-input_surface",
          "type": "frame",
          "width": 320,
          "height": 40,
          "cornerRadius": "$radius.md",
          "fill": "$color.canvas",
          "stroke": { "thickness": 1, "fill": "$color.border.default" },
          "layout": "horizontal",
          "alignItems": "center",
          "padding": ["$space.xs", "$space.md"],
          "children": [
            {
              "id": "text-input_value",
              "type": "text",
              "content": "Placeholder or current value",
              "textGrowth": "auto",
              "fontSize": "$type.body",
              "fill": "$color.text.tertiary"
            }
          ]
