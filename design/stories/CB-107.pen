      "stroke": {
        "thickness": 1,
        "fill": "$color.border.error"
      },
      "descendants": {
        "button-primary_icon": {
          "iconFontName": "trash-2",
          "fill": "$color.text.error",
          "x": 65.5,
          "y": 20
        },
        "button-primary_label": {
          "content": "Delete",
          "fill": "$color.text.error",
          "x": 73.5,
          "y": 12
        }
      }
    },
    {
      "id": "ds_button_disabled",
      "type": "ref",
      "reusable": true,
